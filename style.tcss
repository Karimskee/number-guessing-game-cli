Label {
    width: 100%;
    text-align: center;
}

Button {
    width: 16;
    text-align: center;
    margin: 0 5;
}

WelcomeScreen {
    VerticalScroll {
        align: center middle;
        .header, .explain, .prompt {
            margin: 2 0;
